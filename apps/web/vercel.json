{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && npm install --include=dev --include=optional",
  "buildCommand": "cd ../.. && npm run vercel-build",
  "outputDirectory": "dist",
  "outputFileTracingRoot": "../..",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "../api/dist/**"
    }
  }
}
